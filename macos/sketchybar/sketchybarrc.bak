#!/bin/bash

PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

##### Bar Appearance #####
sketchybar --bar height=22 \
  blur_radius=30 \
  position=top \
  sticky=off \
  padding_left=8 \
  padding_right=8 \
  y_offset=3 \
  margin=6 \
  corner_radius=8 \
  color=0x40000000

#  The format is 0xAABBGGRR where:
#  - AA = Alpha (transparency): 80 = 50% transparent
#  - BB = Blue: 00 = no blue
#  - GG = Green: 00 = no green
#  - RR = Red: 00 = no red
#
#  To adjust transparency:
#  - 0xFF000000 = fully opaque (0% transparent)
#  - 0xCC000000 = 80% opaque (20% transparent)
#  - 0x80000000 = 50% opaque (50% transparent) - current
#  - 0x40000000 = 25% opaque (75% transparent)
#  - 0x00000000 = fully transparent (100% transparent)

##### Changing Defaults #####
sketchybar --default icon.font="PragmataPro:Regular:10.0" \
  icon.color=0xffffffff \
  label.font="PragmataPro:Regular:10.0" \
  label.color=0xffffffff \
  padding_left=4 \
  padding_right=4

##### Adding Left Items (Spaces) #####
# Add spaces label with nerd font icon
# sketchybar --add item spaces_label left \
#   --set spaces_label icon="󰇄" \
#   icon.color=0xffffffff \
#   label.drawing=off \
#   padding_right=8

# Add aerospace workspace change event
sketchybar --add event aerospace_workspace_change

# Add aerospace workspaces (numbers 1-9 and letters A-Z)
for sid in $(aerospace list-workspaces --all); do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
    icon="$sid" \
    icon.padding_left=4 \
    icon.padding_right=4 \
    label.drawing=off \
    background.color=0xffffffff \
    background.corner_radius=4 \
    background.height=13 \
    background.drawing=off \
    click_script="aerospace workspace $sid" \
    script="$PLUGIN_DIR/space.sh $sid" \
    padding_right=0

  sketchybar --add item windows.$sid left \
    --subscribe windows.$sid front_app_switched \
    --set windows.$sid \
    script="$PLUGIN_DIR/windows.sh" \
    icon.drawing=off \
    padding_left=2 \
    padding_right=8
done

##### Adding Center Items (Current App) #####
sketchybar --add item front_app center \
  --set front_app script="$PLUGIN_DIR/front_app.sh" \
  icon.drawing=off \
  update_freq=15 \
  --subscribe front_app front_app_switched

##### Adding Right Items (Battery, Volume, Weather, Date and Time) #####
sketchybar --add item time right \
  --set time update_freq=30 \
  script="$PLUGIN_DIR/time.sh" \
  icon="" \
  label.padding_left=4 \
  padding_left=12

sketchybar --add item date right \
  --set date update_freq=60 \
  script="$PLUGIN_DIR/date.sh" \
  icon="󰃭" \
  label.padding_left=4 \
  padding_left=12

sketchybar --add item battery right \
  --set battery update_freq=60 \
  script="$PLUGIN_DIR/battery.sh" \
  icon="" \
  label.padding_left=4 \
  padding_left=12

# sketchybar --subscribe battery system_woke power_source_change \
#   --add item wifi right \
#   --set wifi script="$PLUGIN_DIR/wifi.sh" \
#   icon="" \
#   label.drawing=off \
#   padding_left=12 \
#   --subscribe wifi wifi_change

sketchybar --add item volume right \
  --set volume script="$PLUGIN_DIR/volume.sh" \
  icon="" \
  label.padding_left=4 \
  padding_left=12 \
  --subscribe volume volume_change

sketchybar --add item weather right \
  --set weather update_freq=300 \
  script="$PLUGIN_DIR/weather.sh" \
  icon="" \
  label.padding_left=4 \
  padding_left=12

##### Finalizing Setup #####
sketchybar --update
